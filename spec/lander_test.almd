import self as lander

// ═══════════════════════════════════════════════════════
// lang_ext
// ═══════════════════════════════════════════════════════
test "lang_ext python" {
  assert_eq(lander.lang_ext("python"), "py")
}

test "lang_ext go" {
  assert_eq(lander.lang_ext("go"), "go")
}

test "lang_ext ruby" {
  assert_eq(lander.lang_ext("ruby"), "rb")
}

test "lang_ext swift" {
  assert_eq(lander.lang_ext("swift"), "swift")
}

test "lang_ext csharp" {
  assert_eq(lander.lang_ext("csharp"), "cs")
}

test "lang_ext dart" {
  assert_eq(lander.lang_ext("dart"), "dart")
}

test "lang_ext kotlin" {
  assert_eq(lander.lang_ext("kotlin"), "kt")
}

test "lang_ext java" {
  assert_eq(lander.lang_ext("java"), "java")
}

test "lang_ext c" {
  assert_eq(lander.lang_ext("c"), "h")
}

test "lang_ext zig" {
  assert_eq(lander.lang_ext("zig"), "zig")
}

test "lang_ext nim" {
  assert_eq(lander.lang_ext("nim"), "nim")
}

test "lang_ext elixir" {
  assert_eq(lander.lang_ext("elixir"), "ex")
}

test "lang_ext php" {
  assert_eq(lander.lang_ext("php"), "php")
}

test "lang_ext lua" {
  assert_eq(lander.lang_ext("lua"), "lua")
}

test "lang_ext cpp" {
  assert_eq(lander.lang_ext("cpp"), "hpp")
}

test "lang_ext rust" {
  assert_eq(lander.lang_ext("rust"), "rs")
}

test "lang_ext javascript" {
  assert_eq(lander.lang_ext("javascript"), "js")
}

test "lang_ext js alias" {
  assert_eq(lander.lang_ext("js"), "js")
}

test "lang_ext scala" {
  assert_eq(lander.lang_ext("scala"), "scala")
}

test "lang_ext julia" {
  assert_eq(lander.lang_ext("julia"), "jl")
}

test "lang_ext powershell" {
  assert_eq(lander.lang_ext("powershell"), "ps1")
}

test "lang_ext ps alias" {
  assert_eq(lander.lang_ext("ps"), "ps1")
}

test "lang_ext unknown" {
  assert_eq(lander.lang_ext("brainfuck"), "txt")
