// ═══════════════════════════════════════════════════════
// find_flag
// ═══════════════════════════════════════════════════════
test "find_flag present" {
  assert_eq(lander.find_flag(["--lang", "python", "file.almd"], "--lang"), "python")
}

test "find_flag absent" {
  assert_eq(lander.find_flag(["file.almd"], "--lang"), "")
}

test "find_flag at end" {
  assert_eq(lander.find_flag(["file.almd", "--lang"], "--lang"), "")
}

test "find_flag multiple flags" {
  assert_eq(lander.find_flag(["--outdir", "out", "--lang", "go"], "--lang"), "go")
}

test "find_flag takes last value" {
  assert_eq(lander.find_flag(["--lang", "python", "--lang", "go"], "--lang"), "go")
}

// ═══════════════════════════════════════════════════════
// has_flag
// ═══════════════════════════════════════════════════════
test "has_flag present" {
  assert_eq(lander.has_flag(["--dry-run", "file.almd"], "--dry-run"), true)
}

test "has_flag absent" {
  assert_eq(lander.has_flag(["file.almd"], "--dry-run"), false)
}

test "has_flag empty" {
  assert_eq(lander.has_flag([], "--dry-run"), false)
}

// ═══════════════════════════════════════════════════════
// collect_positional
// ═══════════════════════════════════════════════════════
test "collect_positional basic" {
  assert_eq(lander.collect_positional(["--lang", "python", "file.almd"]), ["file.almd"])
}

test "collect_positional no flags" {
  assert_eq(lander.collect_positional(["a.almd", "b.almd"]), ["a.almd", "b.almd"])
}

test "collect_positional skips boolean flags" {
  assert_eq(lander.collect_positional(["--dry-run", "file.almd"]), ["file.almd"])
}

test "collect_positional complex" {
  assert_eq(lander.collect_positional([
    "--lang",
    "go",
    "--outdir",
    "dist",
    "--dry-run",
    "mylib.almd"
  ]), ["mylib.almd"])
}

// ═══════════════════════════════════════════════════════
// is_supported
// ═══════════════════════════════════════════════════════
test "is_supported python" {
  assert_eq(lander.is_supported("python"), true)
}

test "is_supported go" {
  assert_eq(lander.is_supported("go"), true)
}

test "is_supported rust" {
  assert_eq(lander.is_supported("rust"), true)
}

test "is_supported cpp" {
  assert_eq(lander.is_supported("cpp"), true)
}

test "is_supported javascript" {
  assert_eq(lander.is_supported("javascript"), true)
}

test "is_supported scala" {
  assert_eq(lander.is_supported("scala"), true)
}

test "is_supported julia" {
  assert_eq(lander.is_supported("julia"), true)
}

test "is_supported powershell" {
  assert_eq(lander.is_supported("powershell"), true)
}

test "is_supported empty" {
  assert_eq(lander.is_supported(""), false)
}

// ═══════════════════════════════════════════════════════
// Consistency checks
// ═══════════════════════════════════════════════════════
test "all lang_ext languages are supported" {
  let langs = [
    "python",
    "go",
    "ruby",
    "swift",
    "csharp",
    "dart",
    "kotlin",
    "java",
    "c",
    "zig",
    "nim",
    "elixir",
    "php",
    "lua",
    "cpp",
    "rust",
    "javascript",
    "scala",
    "julia",
    "powershell"
  ];
  for l in langs {
    assert(lander.is_supported(l), "'${l}' should be supported");
    assert(lander.lang_ext(l) != "txt", "'${l}' should have an extension");
  }
}

test "all 20 languages are supported" {
  let all = [
    "python",
    "go",
    "ruby",
    "swift",
    "csharp",
    "dart",
    "kotlin",
    "java",
    "c",
    "zig",
    "nim",
    "elixir",
    "php",
    "lua",
    "cpp",
    "rust",
    "javascript",
    "scala",
    "julia",
    "powershell"
  ];
  assert_eq(list.len(all), 20);
  for l in all {
    assert(lander.is_supported(l));
  }
}

// ═══════════════════════════════════════════════════════
// Comma-separated lang parsing
// ═══════════════════════════════════════════════════════
test "split single lang" {
  assert_eq(string.split("python", ","), ["python"])
}

test "split multiple langs" {
  assert_eq(string.split("python,go,swift", ","), ["python", "go", "swift"])
}

test "split validates all" {
  let langs = string.split("python,go,swift", ",");
  for l in langs {
    assert(lander.is_supported(l), "${l} should be supported");
  }
}
