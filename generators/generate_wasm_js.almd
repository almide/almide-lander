// generate_wasm_js.almd — Generate TypeScript/JS wrapper for Almide WASM binary
//
// Usage: almide run generate_wasm_js.almd -- interface.json
//
// Uses ABI info from interface.json (struct sizes, field offsets) instead of
// guessing memory layout. This produces correct read/write helpers for all
// record types.

import json
import fs
import env

// ── JSON helpers ──

fn get_str(v: Value, key: String) -> String =
  json.as_string(json.get(v, key) ?? json.from_string("")) ?? ""

fn get_arr(v: Value, key: String) -> List[Value] =
  json.as_array(json.get(v, key) ?? json.array([])) ?? []

fn get_kind(v: Value) -> String = get_str(v, "kind")

fn get_type(v: Value) -> Value = json.get(v, "type") ?? json.null()

// ── ABI helpers ──

fn get_abi(v: Value) -> Value = json.get(v, "abi") ?? json.null()

fn get_abi_size(v: Value) -> Int = {
  let abi = get_abi(v)
  let size = json.as_float(json.get(abi, "size") ?? json.from_float(0.0)) ?? 0.0
  float.to_int(size)
}

fn get_abi_align(v: Value) -> Int = {
  let abi = get_abi(v)
  let align = json.as_float(json.get(abi, "align") ?? json.from_float(0.0)) ?? 0.0
  float.to_int(align)
}

fn get_abi_fields(v: Value) -> List[Value] =
  get_arr(get_abi(v), "fields")

fn get_field_offset(f: Value) -> Int = {
  let offset = json.as_float(json.get(f, "offset") ?? json.from_float(0.0)) ?? 0.0
  float.to_int(offset)
}

fn get_field_size(f: Value) -> Int = {
  let size = json.as_float(json.get(f, "size") ?? json.from_float(0.0)) ?? 0.0
  float.to_int(size)
}

// ── Type mapping ──

fn ts_type(ty: Value) -> String = {
  let kind = get_str(ty, "kind")
  if kind == "float" then "number"
  else if kind == "int" then "number"
  else if kind == "string" then "string"
  else if kind == "bool" then "boolean"
  else if kind == "unit" then "void"
  else if kind == "named" then get_str(ty, "name")
  else if kind == "option" then "(${ts_type(json.get(ty, "inner") ?? json.null())} | null)"
  else if kind == "list" then "${ts_type(json.get(ty, "inner") ?? json.null())}[]"
  else "any"
}

// ── Record type generation ──

fn gen_ts_record(name: String, doc: String, fields: List[Value]) -> List[String] = {
  var lines: List[String] = []
  if doc != "" then lines = lines + ["/** ${doc} */"] else lines = lines
  lines = lines + ["export interface ${name} {"]
  for f in fields {
    let fname = get_str(f, "name")
    let ftype = ts_type(get_type(f))
    lines = lines + ["  ${fname}: ${ftype};"]
  }
  lines = lines + ["}"]
  lines = lines + [""]
  lines
}

// ── Variant type generation ──

fn gen_ts_variant(name: String, doc: String, cases: List[Value]) -> List[String] = {
  var lines: List[String] = []
  if doc != "" then lines = lines + ["/** ${doc} */"] else lines = lines

  var parts: List[String] = []
  for case in cases {
    let cname = get_str(case, "name")
    let payload = json.get(case, "payload")
    match payload {
      some(pl) => {
        if get_kind(pl) == "tuple" then {
          let pfields = get_arr(pl, "fields")
          let n = list.len(pfields)
          if n == 1 then {
            let t0 = ts_type(list.get_or(pfields, 0, json.null()))
            parts = parts + ["{ tag: \"${cname}\"; v0: ${t0} }"]
          } else if n == 2 then {
            let t0 = ts_type(list.get_or(pfields, 0, json.null()))
            let t1 = ts_type(list.get_or(pfields, 1, json.null()))
            parts = parts + ["{ tag: \"${cname}\"; v0: ${t0}; v1: ${t1} }"]
          } else {
            parts = parts + ["{ tag: \"${cname}\" }"]
          }
        } else {
          parts = parts + ["{ tag: \"${cname}\" }"]
        }
      },
      none => {
        parts = parts + ["{ tag: \"${cname}\" }"]
      },
    }
  }

  let union = parts.join("\n  | ")
  lines = lines + ["export type ${name} ="]
  lines = lines + ["  | ${union};"]
  lines = lines + [""]
  lines
}

// ── Variant constructor helpers ──

fn gen_variant_constructors(name: String, cases: List[Value]) -> List[String] = {
  var lines: List[String] = []
  lines = lines + ["export const ${name} = {"]
  for case in cases {
    let cname = get_str(case, "name")
    let factory = string.to_lower(string.slice(cname, 0, 1)) + string.slice(cname, 1)
    let payload = json.get(case, "payload")
    match payload {
      some(pl) => {
        if get_kind(pl) == "tuple" then {
          let pfields = get_arr(pl, "fields")
          let n = list.len(pfields)
          if n == 1 then {
            let t0 = ts_type(list.get_or(pfields, 0, json.null()))
            lines = lines + ["  ${factory}(v0: ${t0}): ${name} { return { tag: \"${cname}\", v0 }; },"]
          } else if n == 2 then {
            let t0 = ts_type(list.get_or(pfields, 0, json.null()))
            let t1 = ts_type(list.get_or(pfields, 1, json.null()))
            lines = lines + ["  ${factory}(v0: ${t0}, v1: ${t1}): ${name} { return { tag: \"${cname}\", v0, v1 }; },"]
          } else {
            lines = lines + ["  ${factory}(): ${name} { return { tag: \"${cname}\" }; },"]
          }
        } else {
          lines = lines + ["  ${factory}(): ${name} { return { tag: \"${cname}\" }; },"]
        }
      },
      none => {
        lines = lines + ["  ${factory}(): ${name} { return { tag: \"${cname}\" }; },"]
      },
    }
  }
  lines = lines + ["};"]
  lines = lines + [""]
  lines
}

// ── Memory layout helpers for records (using ABI info) ─��

fn gen_record_write_read(name: String, fields: List[Value], type_def: Value) -> List[String] = {
  var lines: List[String] = []
  let abi_size = get_abi_size(type_def)
  let abi_fields = get_abi_fields(type_def)

  // Use ABI size if available, otherwise fall back to computed size
  let alloc_size = if abi_size > 0 then abi_size
    else list.len(fields) * 8

  var write_lines: List[String] = []
  var read_lines: List[String] = []

  for f in fields {
    let fname = get_str(f, "name")
    let fkind = get_str(get_type(f), "kind")

    // Find matching ABI field for exact offset
    let matching = abi_fields.filter((af) => get_str(af, "name") == fname)
    let abi_f = list.get_or(matching, 0, json.null())
    let _has_abi = list.len(matching) > 0
    let offset = get_field_offset(abi_f)

    if fkind == "float" then {
      let off_str = int.to_string(offset)
      write_lines = write_lines + ["  view.setFloat64(ptr + ${off_str}, p.${fname}, true);"]
      read_lines = read_lines + ["    ${fname}: view.getFloat64(ptr + ${off_str}, true),"]
    } else if fkind == "int" then {
      let off_str = int.to_string(offset)
      write_lines = write_lines + ["  view.setBigInt64(ptr + ${off_str}, BigInt(p.${fname}), true);"]
      read_lines = read_lines + ["    ${fname}: Number(view.getBigInt64(ptr + ${off_str}, true)),"]
    } else if fkind == "bool" then {
      let off_str = int.to_string(offset)
      write_lines = write_lines + ["  view.setUint8(ptr + ${off_str}, p.${fname} ? 1 : 0);"]
      read_lines = read_lines + ["    ${fname}: view.getUint8(ptr + ${off_str}) !== 0,"]
    } else {
      let off_str = int.to_string(offset)
      write_lines = write_lines + ["  // TODO: marshal ${fname}: ${fkind} at offset ${off_str}"]
      read_lines = read_lines + ["    // TODO: read ${fname}: ${fkind} at offset ${off_str}"]
    }
  }

  lines = lines + ["function write${name}(p: ${name}): number {"]
  lines = lines + ["  const ptr = alloc(${int.to_string(alloc_size)});"]
  lines = lines + ["  refreshView();"]
  lines = lines + write_lines
  lines = lines + ["  return ptr;"]
  lines = lines + ["}"]
  lines = lines + [""]
  lines = lines + ["function read${name}(ptr: number): ${name} {"]
  lines = lines + ["  refreshView();"]
  lines = lines + ["  return {"]
  lines = lines + read_lines
  lines = lines + ["  };"]
  lines = lines + ["}"]
  lines = lines + [""]
  lines
}

// ── Memory layout helpers for variants (using ABI info) ──

fn gen_variant_write(name: String, cases: List[Value], type_def: Value) -> List[String] = {
  var lines: List[String] = []
  let abi_size = get_abi_size(type_def)
  let abi_align = get_abi_align(type_def)

  // Payload offset: tag is i32 (4 bytes), then aligned to max alignment
  let payload_offset = if abi_align > 4 then abi_align else 4

  lines = lines + ["function write${name}(s: ${name}): number {"]
  var ci = 0
  for case in cases {
    let cname = get_str(case, "name")
    let cond = if ci == 0 then "if" else "} else if"
    lines = lines + ["  ${cond} (s.tag === \"${cname}\") {"]
    let payload = json.get(case, "payload")
    match payload {
      some(pl) => {
        if get_kind(pl) == "tuple" then {
          let pfields = get_arr(pl, "fields")
          let n = list.len(pfields)
          let size = if abi_size > 0 then abi_size else 4 + n * 8
          lines = lines + ["    const ptr = alloc(${int.to_string(size)});"]
          lines = lines + ["    refreshView();"]
          lines = lines + ["    view.setInt32(ptr, ${int.to_string(ci)}, true);"]
          var fi = 0
          for _pf in pfields {
            let foffset = payload_offset + fi * 8
            lines = lines + ["    view.setFloat64(ptr + ${int.to_string(foffset)}, (s as any).v${int.to_string(fi)}, true);"]
            fi = fi + 1
          }
          lines = lines + ["    return ptr;"]
        } else {
          let size = if abi_size > 0 then abi_size else 4
          lines = lines + ["    const ptr = alloc(${int.to_string(size)});"]
          lines = lines + ["    refreshView();"]
          lines = lines + ["    view.setInt32(ptr, ${int.to_string(ci)}, true);"]
          lines = lines + ["    return ptr;"]
        }
      },
      none => {
        let size = if abi_size > 0 then abi_size else 4
        lines = lines + ["    const ptr = alloc(${int.to_string(size)});"]
        lines = lines + ["    refreshView();"]
        lines = lines + ["    view.setInt32(ptr, ${int.to_string(ci)}, true);"]
        lines = lines + ["    return ptr;"]
      },
    }
    ci = ci + 1
  }
  lines = lines + ["  }"]
  lines = lines + ["  throw new Error(\"Unknown ${name} tag\");"]
  lines = lines + ["}"]
  lines = lines + [""]
  lines
}

// ── Public API function ──

fn gen_api_fn(f: Value) -> List[String] = {
  let fname = get_str(f, "name")
  let params = get_arr(f, "params")
  let ret = json.get(f, "return") ?? json.null()
  let doc = get_str(f, "doc")
  let ret_kind = get_str(ret, "kind")

  let params_ts = params.map((p) => {
    let ptype = json.get(p, "type") ?? json.null()
    "${get_str(p, "name")}: ${ts_type(ptype)}"
  })

  let call_args = params.map((p) => {
    let ptype = json.get(p, "type") ?? json.null()
    if get_kind(ptype) == "named" then "write${get_str(ptype, "name")}(${get_str(p, "name")})"
    else get_str(p, "name")
  })

  let params_str = params_ts.join(", ")
  let args_str = call_args.join(", ")
  let ret_ts = ts_type(ret)

  var lines: List[String] = []
  if doc != "" then lines = lines + ["/** ${doc} */"] else lines = lines
  lines = lines + ["export function ${fname}(${params_str}): ${ret_ts} {"]
  if ret_kind == "named" then {
    let ret_name = get_str(ret, "name")
    lines = lines + ["  return read${ret_name}(wasm_${fname}(${args_str}));"]
  } else if ret_kind == "string" then {
    lines = lines + ["  return readString(wasm_${fname}(${args_str}));"]
  } else {
    lines = lines + ["  return wasm_${fname}(${args_str});"]
  }
  lines = lines + ["}"]
  lines = lines + [""]
  lines
}

// ── DTS declaration for function ──

fn gen_dts_fn(f: Value) -> List[String] = {
  let fname = get_str(f, "name")
  let params = get_arr(f, "params")
  let ret = json.get(f, "return") ?? json.null()
  let doc = get_str(f, "doc")

  let params_ts = params.map((p) => {
    let ptype = json.get(p, "type") ?? json.null()
    "${get_str(p, "name")}: ${ts_type(ptype)}"
  })
  let params_str = params_ts.join(", ")
  let ret_ts = ts_type(ret)

  var lines: List[String] = []
  if doc != "" then lines = lines + ["/** ${doc} */"] else lines = lines
  lines = lines + ["export function ${fname}(${params_str}): ${ret_ts};"]
  lines
}

// ── Main ──

effect fn main() -> Unit = {
  let args = env.args()
  let iface_path = list.get(args, 0) ?? "interface.json"

  let iface_text = fs.read_text(iface_path)!
  let iface = json.parse(iface_text)!

  let module_name = get_str(iface, "module")
  let types = get_arr(iface, "types")
  let functions = get_arr(iface, "functions")

  var lines: List[String] = []
  var dts_lines: List[String] = []

  lines = lines + ["/**"]
  lines = lines + [" * TypeScript wrapper for the Almide ${module_name} WASM module."]
  lines = lines + [" * AUTO-GENERATED by almide-lander — do not edit."]
  lines = lines + [" */"]
  lines = lines + [""]

  dts_lines = dts_lines + ["// Type declarations for almide_${module_name}"]
  dts_lines = dts_lines + [""]

  // Public types
  lines = lines + ["// ---------- Public types ----------"]
  for t in types {
    let name = get_str(t, "name")
    let doc = get_str(t, "doc")
    let kind = json.get(t, "kind") ?? json.null()
    let k = get_kind(kind)
    if k == "record" then {
      let rec_lines = gen_ts_record(name, doc, get_arr(kind, "fields"))
      lines = lines + rec_lines
      dts_lines = dts_lines + rec_lines
    } else if k == "variant" then {
      let var_lines = gen_ts_variant(name, doc, get_arr(kind, "cases"))
      lines = lines + var_lines
      dts_lines = dts_lines + var_lines
    } else {
      lines = lines
    }
  }

  // Variant constructor helpers
  for t in types {
    let kind = json.get(t, "kind") ?? json.null()
    if get_kind(kind) == "variant" then {
      lines = lines + gen_variant_constructors(get_str(t, "name"), get_arr(kind, "cases"))
    } else lines = lines
  }

  // Internals
  lines = lines + ["// ---------- Internals ----------"]
  lines = lines + [""]
  lines = lines + ["let memory: WebAssembly.Memory;"]
  lines = lines + ["let view: DataView;"]
  lines = lines + ["let alloc: (n: number) => number;"]
  for f in functions {
    let fname = get_str(f, "name")
    lines = lines + ["let wasm_${fname}: Function;"]
  }
  lines = lines + [""]
  lines = lines + ["function refreshView(): void { view = new DataView(memory.buffer); }"]
  lines = lines + [""]

  // Memory layout helpers (using ABI info from interface.json)
  lines = lines + ["// ---------- Memory layout helpers ----------"]
  lines = lines + [""]
  for t in types {
    let name = get_str(t, "name")
    let kind = json.get(t, "kind") ?? json.null()
    let k = get_kind(kind)
    if k == "record" then {
      lines = lines + gen_record_write_read(name, get_arr(kind, "fields"), t)
    } else if k == "variant" then {
      lines = lines + gen_variant_write(name, get_arr(kind, "cases"), t)
    } else lines = lines
  }

  // String reader
  lines = lines + ["function readString(ptr: number): string {"]
  lines = lines + ["  refreshView();"]
  lines = lines + ["  const len = view.getInt32(ptr, true);"]
  lines = lines + ["  const bytes = new Uint8Array(memory.buffer, ptr + 4, len);"]
  lines = lines + ["  return new TextDecoder().decode(bytes);"]
  lines = lines + ["}"]
  lines = lines + [""]

  // Public API
  lines = lines + ["// ---------- Public API ----------"]
  lines = lines + [""]
  for f in functions {
    lines = lines + gen_api_fn(f)
    dts_lines = dts_lines + gen_dts_fn(f)
  }

  // Init function
  lines = lines + ["// ---------- Initialisation ----------"]
  lines = lines + [""]
  lines = lines + ["export async function init(wasmPath: string): Promise<void> {"]
  lines = lines + ["  const bytes = await Deno.readFile(wasmPath);"]
  lines = lines + ["  const mod = new WebAssembly.Module(bytes);"]
  lines = lines + ["  const importObject: Record<string, Record<string, WebAssembly.ImportValue>> = {};"]
  lines = lines + ["  for (const imp of WebAssembly.Module.imports(mod)) {"]
  lines = lines + ["    if (!importObject[imp.module]) importObject[imp.module] = {};"]
  lines = lines + ["    if (imp.kind === \"function\") {"]
  lines = lines + ["      importObject[imp.module][imp.name] = (..._args: unknown[]) => 0;"]
  lines = lines + ["    }"]
  lines = lines + ["  }"]
  lines = lines + ["  const instance = new WebAssembly.Instance(mod, importObject);"]
  lines = lines + ["  const ex = instance.exports;"]
  lines = lines + ["  memory = ex.memory as WebAssembly.Memory;"]
  lines = lines + ["  alloc = ex.__alloc as (n: number) => number;"]
  for f in functions {
    let fname = get_str(f, "name")
    lines = lines + ["  wasm_${fname} = ex.${fname} as Function;"]
  }
  lines = lines + ["  refreshView();"]
  lines = lines + ["}"]

  fs.write("almide_${module_name}.ts", lines.join("\n"))!
  fs.write("almide_${module_name}.d.ts", dts_lines.join("\n"))!

  println("Generated: almide_${module_name}.ts + almide_${module_name}.d.ts")
}
